# Alpaca API credentials for the openbb-alpaca provider.
# Copy to .env (git-ignored) and fill in your values.
#   cp .env.example .env
# These env vars are read as `alpaca_api_key` / `alpaca_api_secret` by OpenBB.

ALPACA_API_KEY=
ALPACA_API_SECRET=

# Feed: iex (free), sip (paid consolidated), otc (over-the-counter)
# ALPACA_FEED=iex
